# Judge A: Gemini (required for provider mode)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_JUDGE_A_MODEL=gemini-2.0-flash-lite

# Judge B: Second Gemini model (enables dual-model mode for final scoring)
# Must be a different model from Judge A to avoid same-model review warning
GEMINI_JUDGE_B_MODEL=gemini-2.5-flash

# Provider mode (gemini is the only supported provider)
JUDGE_PROVIDER=gemini

# Enable dual-model scoring (both required for APPROVE decision)
# Set both to true only for the final submission run to conserve quota
FINAL_PROVIDER_RUN=false
ALLOW_JUDGE_B_FINAL=false

# Quota-safe execution settings
JUDGE_BATCH_SIZE=5
JUDGE_CONCURRENCY=4
JUDGE_REQUESTS_PER_MINUTE=6

# Retry and timeout settings
JUDGE_TIMEOUT_SECONDS=45
JUDGE_MAX_RETRIES=2
JUDGE_RETRY_BASE_SECONDS=15
JUDGE_RETRY_MAX_SECONDS=120

# Judge B daily budget (free-tier safe: 20 requests/day, 4 reserved for retries)
JUDGE_B_DAILY_REQUEST_BUDGET=20
JUDGE_B_RESERVED_RETRY_BUDGET=4

# Result cache (reduces cost on re-runs)
JUDGE_CACHE_ENABLED=true
JUDGE_CACHE_PATH=.cache/judge_results.json

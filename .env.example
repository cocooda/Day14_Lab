# Judge A: Gemini
GEMINI_API_KEY=your_gemini_key
GEMINI_JUDGE_A_MODEL=gemini-3.1-flash-lite

# Judge B: Fireworks AI
FIREWORKS_API_KEY=your_fireworks_key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_JUDGE_B_MODEL=accounts/fireworks/models/deepseek-v3

# Provider mode
JUDGE_PROVIDER=gemini_fireworks
JUDGE_MODE=provider_gemini_fireworks_dual_model

# Quota-safe execution
JUDGE_BATCH_SIZE=5
JUDGE_CONCURRENCY=1
JUDGE_REQUESTS_PER_MINUTE=6

JUDGE_TIMEOUT_SECONDS=120
JUDGE_MAX_RETRIES=2
JUDGE_RETRY_BASE_SECONDS=15
JUDGE_RETRY_MAX_SECONDS=120

JUDGE_CACHE_ENABLED=true
JUDGE_CACHE_PATH=.cache/judge_results.json